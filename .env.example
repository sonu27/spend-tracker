# GoCardless Bank Account Data API credentials (required)
# Sign up at https://bankaccountdata.gocardless.com/
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Public URL of the app (optional, defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# SQLite database file path (optional, defaults to file:local.db)
# DB_FILE_NAME=file:local.db
